# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit your actual .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key – needed for Claude (the LLM brain of the engineer).
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key – needed ONLY when using the OpenAI Whisper/TTS providers.
# If you use local providers (STT_PROVIDER=local, TTS_PROVIDER=edge-tts) you
# can leave this blank.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Audio Provider Selection ─────────────────────────────────────────────────
# Speech-to-Text provider: "openai" (default) or "local" (faster-whisper / whisper.cpp)
# STT_PROVIDER=openai

# Text-to-Speech provider: "openai" (default) or "edge-tts" (Microsoft Edge TTS, free)
# TTS_PROVIDER=openai

# ── Local STT Settings (used when STT_PROVIDER=local) ────────────────────────
# Whisper model size: tiny, base (default), small, medium, large-v3
# Larger models are more accurate but use more RAM and are slower.
# WHISPER_MODEL_SIZE=base

# Compute device: auto (default), cpu, cuda
# WHISPER_DEVICE=auto

# ── Edge-TTS Settings (used when TTS_PROVIDER=edge-tts) ──────────────────────
# Voice name – run `edge-tts --list-voices` for all options.
# Default: en-GB-RyanNeural (deep British male – good for race engineer)
# EDGE_TTS_VOICE=en-GB-RyanNeural

# ── Optional ──────────────────────────────────────────────────────────────────
# LLM model override (default: claude-3-5-haiku-20241022)
# LLM_MODEL=claude-3-5-haiku-20241022

# TTS voice for OpenAI – choose from: alloy, echo, fable, onyx, nova, shimmer
# 'onyx' is a deep authoritative voice (good for race engineer)
# TTS_VOICE=onyx

# UDP bind address for the F1 telemetry listener (default: 127.0.0.1 = localhost only).
# Set to "" or "0.0.0.0" to accept telemetry from another machine on the LAN
# (e.g., if your gaming PC is separate from the machine running this server).
# UDP_BIND_ADDRESS=127.0.0.1

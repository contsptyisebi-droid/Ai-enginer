# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit your actual .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# OpenAI API key – ALWAYS needed for Whisper (speech-to-text) and TTS (text-to-speech).
# Get yours at: https://platform.openai.com/api-keys
# Also used as the LLM when LLM_PROVIDER is "openai" (default if no Anthropic key is set).
OPENAI_API_KEY=sk-...

# ── Claude / Anthropic (recommended for LLM) ─────────────────────────────────
# Set this to use Claude as the LLM instead of GPT-4o.
# When set, the LLM automatically switches to Claude (STT & TTS still use OpenAI).
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
# LLM provider: "openai" or "anthropic". Auto-detected from API keys if omitted.
# If both API keys are set and this is omitted, Anthropic/Claude is preferred.
# LLM_PROVIDER=anthropic

# LLM model override (default: gpt-4o for OpenAI, claude-3-5-haiku-20241022 for Anthropic)
# LLM_MODEL=claude-3-5-haiku-20241022

# TTS voice – choose from: alloy, echo, fable, onyx, nova, shimmer
# 'onyx' is a deep authoritative voice (good for race engineer)
# TTS_VOICE=onyx

# UDP bind address for the F1 telemetry listener (default: 127.0.0.1 = localhost only).
# Set to "" or "0.0.0.0" to accept telemetry from another machine on the LAN
# (e.g., if your gaming PC is separate from the machine running this server).
# UDP_BIND_ADDRESS=127.0.0.1

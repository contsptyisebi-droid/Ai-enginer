# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit your actual .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key – needed for Claude (the LLM brain of the engineer).
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key – needed for Whisper (speech-to-text) and TTS (text-to-speech).
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────────────────
# LLM model override (default: claude-3-5-haiku-20241022)
# LLM_MODEL=claude-3-5-haiku-20241022

# TTS voice – choose from: alloy, echo, fable, onyx, nova, shimmer
# 'onyx' is a deep authoritative voice (good for race engineer)
# TTS_VOICE=onyx

# UDP bind address for the F1 telemetry listener (default: 127.0.0.1 = localhost only).
# Set to "" or "0.0.0.0" to accept telemetry from another machine on the LAN
# (e.g., if your gaming PC is separate from the machine running this server).
# UDP_BIND_ADDRESS=127.0.0.1
